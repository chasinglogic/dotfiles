#!/usr/bin/env bun
// vi: ft=typescript

import { createInterface } from "node:readline";

type LogRecord = Record<string, unknown>;

const COLORS = {
    reset: "\u001b[0m",
    red: "\u001b[31m",
    yellow: "\u001b[33m",
    cyan: "\u001b[36m",
};

const TIMESTAMP_KEYS = ["time", "timestamp", "ts"] as const;
const LEVEL_KEYS = ["level", "levelname", "level_name"] as const;
const MESSAGE_KEYS = ["message", "msg"] as const;

const EXCLUDE_KEYS = new Set<string>([...TIMESTAMP_KEYS, ...LEVEL_KEYS, ...MESSAGE_KEYS]);

let cachedTimestampKey: string | undefined;
let cachedLevelKey: string | undefined;
let cachedMessageKey: string | undefined;

function colorForLevel(level: unknown): string {
    const name = String(level).toUpperCase();
    switch (name) {
        case "INFO":
            return COLORS.cyan;
        case "WARN":
        case "WARNING":
            return COLORS.yellow;
        case "ERR":
        case "ERROR":
            return COLORS.red;
        default:
            return COLORS.reset;
    }
}

function discoverKey(candidates: readonly string[], data: LogRecord): string | undefined {
    for (const key of candidates) {
        if (data[key] !== undefined && data[key] !== null) {
            return key;
        }
    }
    return undefined;
}

function timestampKey(data: LogRecord): string | undefined {
    if (!cachedTimestampKey) {
        cachedTimestampKey = discoverKey(TIMESTAMP_KEYS, data);
    }
    return cachedTimestampKey;
}

function levelKey(data: LogRecord): string | undefined {
    if (!cachedLevelKey) {
        cachedLevelKey = discoverKey(LEVEL_KEYS, data);
    }
    return cachedLevelKey;
}

function messageKey(data: LogRecord): string | undefined {
    if (!cachedMessageKey) {
        cachedMessageKey = discoverKey(MESSAGE_KEYS, data);
    }
    return cachedMessageKey;
}

function isRecord(value: unknown): value is LogRecord {
    return typeof value === "object" && value !== null && !Array.isArray(value);
}

function printFields(obj: unknown, nestingLevel = 1): void {
    if (!isRecord(obj)) {
        return;
    }

    const prefix = "\t".repeat(nestingLevel);
    for (const [key, value] of Object.entries(obj)) {
        if (EXCLUDE_KEYS.has(key)) {
            continue;
        }

        if (isRecord(value)) {
            console.log(`${prefix}${key} = {`);
            printFields(value, nestingLevel + 1);
            console.log(`${prefix}}`);
        } else if (Array.isArray(value)) {
            console.log(`${prefix}${key} = {`);
            const indexed = value.reduce<LogRecord>((acc, entry, index) => {
                acc[String(index)] = entry;
                return acc;
            }, {});
            printFields(indexed, nestingLevel + 1);
            console.log(`${prefix}}`);
        } else {
            console.log(`${prefix}${key} = ${String(value)}`);
        }
    }
}

function extractPrimaryFields(data: LogRecord): { level: unknown; timestamp: string; message: string } {
    const lvlKey = levelKey(data);
    const tsKey = timestampKey(data);
    const msgKey = messageKey(data);

    const level = lvlKey ? data[lvlKey] ?? "INFO" : "INFO";
    const timestamp = tsKey ? formatField(data[tsKey]) : "";
    const message = msgKey ? formatField(data[msgKey]) : "";

    return { level, timestamp, message };
}

function formatField(value: unknown): string {
    if (value === undefined || value === null) {
        return "";
    }
    return typeof value === "string" ? value : String(value);
}

function prettyPrint(line: string): void {
    const parsed = JSON.parse(line);
    if (!isRecord(parsed)) {
        throw new Error("JSON line is not an object");
    }

    const { level, timestamp, message } = extractPrimaryFields(parsed);
    const color = colorForLevel(level);
    const parts = [`${color}${String(level).toUpperCase()}${COLORS.reset}`];
    if (timestamp) {
        parts.push(timestamp);
    }
    if (message) {
        parts.push(message);
    }

    console.log(parts.join(" "));
    printFields(parsed, 1);
}

const rl = createInterface({
    input: process.stdin,
    crlfDelay: Infinity,
    terminal: false,
});

rl.on("line", (rawLine: string) => {
    const line = rawLine.endsWith("\r") ? rawLine.slice(0, -1) : rawLine;
    if (line.length === 0) {
        return;
    }

    try {
        prettyPrint(line);
    } catch {
        console.log(`NON-JSON LINE: ${line}`);
    }
});

rl.on("close", () => {
    process.exit(0);
});
