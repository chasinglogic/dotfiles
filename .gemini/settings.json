{
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    },
    "enablePermanentToolApproval": true
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "defaultApprovalMode": "plan"
  },
  "ui": {
    "inlineThinkingMode": "full",
    "autoThemeSwitching": false,
    "showMemoryUsage": true,
    "showCitations": true,
    "showModelInfoInChat": true
  },
  "tools": {
    "shell": {
      "showColor": true
    },
    "disableLLMCorrection": false
  },
  "experimental": {
    "modelSteering": true,
    "directWebFetch": true
  },
  "telemetry": {
    "enabled": true,
    "target": "local",
    "otlpEndpoint": "http://raza.beefalo-drum.ts.net:4317"
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  }
}